{
  "name": "cryptovoxels",
  "license": "BSL-1.1",
  "version": "8.16.1",
  "engines": {
    "node": "25"
  },
  "cacheDirectories": [
    "node_modules",
    ".build"
  ],
  "description": "",
  "main": "index.js",
  "scripts": {
    "mp": "concurrently -k \"npm run watch-css\" \"npm run webpack:start\" \"npm run multiplayer:dev\"",
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 NODE_ENV=development concurrently -k \"npm run watch-css\" \"npm run server:dev\" \"npm run webpack:web:start\" \"npm run webpack:client:start\" \"npm run multiplayer:dev\"",
    "dev:stable": "NODE_TLS_REJECT_UNAUTHORIZED=0 NODE_ENV=development concurrently -k \"npm run watch-css\" \"npm run webpack:server:stable\" \"npm run webpack:web:start\" \"npm run webpack:client:start\" \"npm run multiplayer:dev\"",
    "server:dev": "tsx --watch server/boot.ts",
    "server:start": "tsx server/boot.ts",
    "build": "npm run compile-css && npm run webpack:build && npm run build:scripting",
    "build:scripting": "esbuild scripting/index.ts --bundle --minify --outfile=dist/scripting-host.js --metafile=scripting/meta.json",
    "build:scripting:watch": "esbuild scripting/index.ts --bundle --minify --outfile=dist/scripting-host.js --metafile=scripting/meta.json --watch",
    "start:sample": "concurrently \"npm run server -- fastload\" \"npm run webpack:client:start\" \"npm run webpack:web:start\" \"npm run watch-css\"",
    "start": "npm run webpack:server:build && node server/bundle_server.js",
    "webpack:start": "concurrently \"npm run webpack:server:start\" \"npm run webpack:web:start\" \"npm run webpack:client:start\"",
    "webpack:start-ssl": "NODE_TLS_REJECT_UNAUTHORIZED=0 concurrently \"npm run webpack:server:start\" \"npm run webpack:web:start-ssl\" \"npm run webpack:client:start-ssl\"",
    "webpack:stable": "concurrently \"npm run webpack:server:stable\" \"npm run webpack:web:start\" \"npm run webpack:client:start\"",
    "webpack:stable-ssl": "NODE_TLS_REJECT_UNAUTHORIZED=0 concurrently \"npm run webpack:server:stable\" \"npm run webpack:web:start-ssl\" \"npm run webpack:client:start-ssl\"",
    "webpack:build": "mkdir -p .build && concurrently \"npm run webpack:server:build\" \"npm run webpack:web:build\" \"npm run webpack:client:build\"",
    "webpack:web:start": "npx webpack serve --mode=development --config webpack/webpack-web.config",
    "webpack:web:start-ssl": "npx webpack serve --mode=development --config webpack/webpack-web-ssl.config",
    "webpack:web:build": "npx webpack --mode=production --config webpack/webpack-web.config",
    "webpack:client:start": "npx webpack serve --mode=development --config webpack/webpack-client.config",
    "webpack:client:start-ssl": "npx webpack serve --mode=development --config webpack/webpack-client-ssl.config",
    "webpack:client:build": "NODE_ENV=production webpack --mode=production --config webpack/webpack-client.config",
    "dev:webpack:client:build": "NODE_ENV=development webpack --mode=development --config webpack/webpack-client.config",
    "webpack:server:start": "concurrently \"npm run webpack:server:build:watch\" \"npm run webpack:server:start:watch\"",
    "webpack:server:build": "npx webpack --mode=production --config webpack/webpack-server.config.js",
    "webpack:server:build:watch": "npx webpack --watch --mode=development --config webpack/webpack-server.config",
    "webpack:server:start:watch": "nodemon --watch server/bundle_server.js server/bundle_server.js",
    "webpack:server:stable": "npx webpack --mode=development --config webpack/webpack-server.config.js && node server/bundle_server.js",
    "precommit": "tsc --noEmit --project tsconfig.precommit.json && prettier --write --log-level warn .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "typescript:check": "tsc --noEmit --project tsconfig.check.json",
    "test:build": "npm run typescript:check && npm run prettier && npm run build:scripting",
    "test:ci": "vitest run --reporter=verbose",
    "css": "lessc web/src/style/web.less dist/web.css && lessc web/src/style/client.less dist/client.css",
    "watch-css": "concurrently -k \"less-watch-compiler web/src/style dist web.less\" \"less-watch-compiler web/src/style dist client.less\"",
    "compile-css": "lessc web/src/style/web.less dist/web.css && lessc web/src/style/client.less dist/client.css",
    "migrate": "NODE_TLS_REJECT_UNAUTHORIZED=0 tsx server/migration/migrate.ts",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "format": "npm run prettier",
    "format:check": "npm run prettier:check",
    "bench": "tsx ./src/benchmarks/vox-reader-bench.ts",
    "bundle-deps": "node vendor/library/index.js && git add dist/vendor/**",
    "multiplayer:dev": "tsx --watch multiplayer/src/index.ts",
    "multiplayer:start": "tsx multiplayer/src/index.ts",
    "compressor:dev": "tsx --watch compressor/src/index.ts",
    "compressor:start": "tsx compressor/src/index.ts",
    "compressor:test": "vitest run --project compressor"
  },
