        "script": "let r1 = parcel.getFeatureById('rocket1')\nlet startButton = parcel.getFeatureById('butt')\n\nlet boomloud_right = parcel.getFeatureById('boomloud-right')\nlet boomfizz_right = parcel.getFeatureById('boomfizz-right')\nlet boomloud_left = parcel.getFeatureById('boomloud-left')\nlet boomfizz_left = parcel.getFeatureById('boomfizz-left')\n\nlet launch1_right= parcel.getFeatureById('launch1-right')\nlet launch2_right= parcel.getFeatureById('launch2-right')\nlet launch1_left= parcel.getFeatureById('launch1-left')\nlet launch2_left= parcel.getFeatureById('launch2-left')\n\nlet listBooms = [\n  'https://www.dropbox.com/s/js0u3j2vzbv1j3g/Boom_blue_strings.vox?dl=0',\n  'https://www.dropbox.com/s/htdeff0va42r31t/Boom_blue.vox?dl=0',\n  'https://www.dropbox.com/s/xyss3pi7q3h70eg/Boom_multicolor.vox?dl=0',\n  'https://www.dropbox.com/s/xyss3pi7q3h70eg/Boom_multicolor.vox?dl=0',\n  'https://www.dropbox.com/s/shll12h4dojhoku/Boom_pink.vox?dl=0',\n  'https://www.dropbox.com/s/yqpnq5s5ycdpnji/Boom_red_multicolor.vox?dl=0',\n  'https://www.dropbox.com/s/n6i9bh8nfu31q6z/Boom_red.vox?dl=0',\n  'https://www.dropbox.com/s/14otr18auxoy32h/Boom_yellow.vox?dl=0',\n  'https://www.dropbox.com/s/70j9q1scbfvf4kr/Boom_yellow2.vox?dl=0'\n  ]\n\nlet listRockets = [\n  'https://www.dropbox.com/s/t9tuo84091jy5ih/Firework_blue.vox?dl=0',\n  'https://www.dropbox.com/s/wzj5g1zxicov4ch/Firework_orange.vox?dl=0',\n  'https://www.dropbox.com/s/clxksbf4b4tkgl8/Firework_PS.vox?dl=0',\n  'https://www.dropbox.com/s/fo8jkbol9qqicyj/Firework_red.vox?dl=0'\n  ]\n\nlet audio={\n  boom_right:[boomloud_right,boomfizz_right],\n  boom_left:[boomloud_left,boomfizz_left],\nlaunch_right:[launch1_right,launch2_right],\nlaunch_left:[launch1_left,launch2_left],\n  fountain:['https://www.dropbox.com/s/zto0ga1ixnqs0m1/fount.wav?dl=0']\n}\n\nlet minBoomSize = 5\n\nlet xboundaries = [7,-7]\nlet zboundaries = [-4.5,-7.5]\n\nfunction randomPositionWithinBoundaries(){\nlet x = Math.random()*(xboundaries[0]+Math.abs(xboundaries[1]))-Math.abs(xboundaries[1])\nlet z = Math.random()*(zboundaries[0]+Math.abs(zboundaries[1]))-Math.abs(zboundaries[1])\nreturn [x,0.75,z]\n}\n\n\nstartButton.on('click',e=>{\nlet o = createRocket()\n    launch(o)\nsetTimeout((p)=>{parcel.removeFeature(o)},4000)\n})\n\nfunction makeAnimation(f){\n    console.log('make anim')\nlet height = Math.random()*8\n  \nlet animation = f.createAnimation('position')\n\nanimation.setKeys([{\n  frame: 30, // standard is 30 fps (means it take 1 second)\n  value: f.position.add( new Vector3(0,9+height,0) )\n}])\n  \n  return {anim:animation,height:height}\n}\n\nfunction resetRocket(f){\n  f.set({position:positionToArray(f)})\n}\n\nfunction positionToArray(f){\nreturn [f.position.x,f.position.y,f.position.z]\n}\n\nfunction launch(f){\n  let launchData = makeAnimation(f)\n    console.log('launch')\nlaunchSound(positionToArray(f))\n  f.startAnimations( [launchData.anim] )\n  setTimeout((e)=>{explode(f,launchData.height)},1000)\n}\n\nfunction explode(f,height){\n  console.log('explode')\n  resetRocket(f)\n  createAndRemoveExplosion([f.position.x,f.position.y+height+3,f.position.z])\n}\n\nfunction randomFromArray(arr){\n  return arr[Math.floor(Math.random() * arr.length)]\n}\n\n/* ------------------- Booms and rockets functions ---------------- */\n\nfunction createAndRemoveExplosion(position){\n  let a = parcel.createFeature('vox-model')\n  a.set({url:randomFromArray(listBooms)})\n  a.set({scale:[minBoomSize+Math.random()*4,minBoomSize+Math.random()*4,minBoomSize+Math.random()*4]})\n  a.set({position:position})\n  boomSound(position)\n  setTimeout((r)=>parcel.removeFeature(a),2000+Math.random()*2000)\n}\n\nfunction createRocket(){\nlet position = randomPositionWithinBoundaries()\n  console.log(position)\n  let a = parcel.createFeature('vox-model')\n  a.set({url:randomFromArray(listRockets)})\n  a.set({scale:[1,1,1]})\n  a.set({position:position})\nreturn a\n}\n\n/* ------------------- Audio functions ---------------- */\n\nfunction boomSound(position){\nif(position[0]<0){\nrandomFromArray(audio.boom_right).play()\n}else{\nrandomFromArray(audio.boom_left).play()\n}\n}\n\nfunction launchSound(position){\nif(position[0]<0){\nrandomFromArray(audio.launch_right).play()\n}else{\nrandomFromArray(audio.launch_left).play()\n}\n}\n\n",
