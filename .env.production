AWS_REGION=ap-southeast-2

# all of the chunks in a list that we can then load
CHUNK_ENDPOINT=https://www.cryptovoxels.com/grid/chunks.json

# Where to load texture assets from
ASSET_PATH=https://www.cryptovoxels.com

API=/api
# API=http://192.168.1.15:8050/api

CLIENT_JS_FILE_NAME=client

# Where to get static website css / js
WEB_ASSETS=https://retro.voxels.com
WEB_JS=https://retro.voxels.com/web.js

# Web flags
SUPPORT_ENABLED=false

# Address of the deployed contract
CONTRACT_ADDRESS=0x79986aF15539de2db9A5086382daEdA917A9CF0C
CREATOR_ADDRESS=0x4f857add94d3c54144a7a1220da0399a187e1c5c
OWNER_ADDRESS=0xa253D7cd38dC2D0B2E65AD42a7e4bEB3C60A83aD
COLOR_ADDRESS=0x3867ef780a3afcf1201ef4f2acc6a46e3bd1eb88
WEARABLE_CONTRACT_ADDRESS=0xa58b5224e2fd94020cb2837231b2b0e4247301a6
COMPANY_WALLET=0xa253D7cd38dC2D0B2E65AD42a7e4bEB3C60A83aD
RINKEBY_CONTRACT_ADDRESS=0x13dBD857f5513C0d65a3a0690cF1e58a44D6a79e

# Map path
MAP_URL=https://map.voxels.com
IMG_URL=https://cdn.cryptovoxels.com/node
SCRIPTING_URL=https://untrusted.cryptovoxels.com
IMG_HOST=https://cdn.cryptovoxels.com
SOUNDS_URL=https://img.cryptovoxels.com/sounds
MUSIC_URL=https://img.cryptovoxels.com/music
MODELS_URL=https://cdn.cryptovoxels.com/models

# Boomboxes
BROADCAST_URL=wss://broadcast.cryptovoxels.com/broadcast

# Grid socket
#GRID_SOCKET_URI=wss://cryptovoxels.herokuapp.com/grid/socket

# The DB table name used for baking jobs, normally "jobs". Use a different value to run multiple distinct baker versions simultaneously.
# Must match the regex /^jobs[a-z0-9_]*$/
JOBS_TABLE_NAME=jobs
