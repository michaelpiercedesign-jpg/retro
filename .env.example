##################################################################
###### CORE CONFIGURATION - Required for local development ######
##################################################################

# Database: PostgreSQL connection string (ask team for password on Slack)
# Used by: server, render process
DATABASE_URL=postgres://localhost:5432/voxels

# Security: JWT token for multiplayer server authentication
# Get from your cloud provider or generate a secret
# Used by: multiplayer server, server authentication
JWT_SECRET="leeeeeeeroyjeeeeeeenkinnggggggg"

# Logging: Enable/disable debug logs
# Used by: server logger, multiplayer server logger
DEBUG_LOG=true

# Cache: Redis connection for multiplayer chat, event bus, real-time features
# For local dev: Install Redis (brew install redis) and use redis://localhost:6379
# Used by: multiplayer server (chat, events), main server (event publishing)
REDIS_URL=<secret>

# Testing: For local scripting/upload testing
# You need to add `127.0.0.1 untrusted.cryptovoxels.local` to your `/etc/hosts` file if you want to test scripting
# You'll also need https://github.com/cryptovoxels/media running if you want to test user uploads locally

# Tip: Replace localhost with your network IP if you want to test on another device

##################################################################
###### INFRASTRUCTURE - Don't change unless testing services ####
##################################################################

# API: Base API path for all endpoints
# Used by: web UI, client
API=/api

# Timezone: Node.js timezone for database date interpretation
# Used by: Node.js runtime (automatically)
TZ=UTC

# Assets: Base URL for loading textures, models, static files
# Used by: client, web UI (heavily used - 47 references)
ASSET_PATH=http://localhost:9000

# Build: Client JavaScript bundle filename
# Used by: web UI for loading game client
CLIENT_JS_FILE_NAME=client

# Services: External service endpoints
# MULTIPLAYER_HOST: WebSocket server for multiplayer features
# SUBGRAPHS_ROUTER: GraphQL endpoint for blockchain data queries
# WIKI_URL: Wiki content endpoint
# MEDIA_UPLOAD_ENDPOINT: Local media upload service (needs cryptovoxels/media running)
MULTIPLAYER_HOST=ws://localhost:3780
SUBGRAPHS_ROUTER=https://subgraphs.crvox.com
WIKI_URL=https://wiki.cryptovoxels.com
MEDIA_UPLOAD_ENDPOINT=http://localhost:3000/upload

##################################################################
###### BLOCKCHAIN API KEYS - Optional for local dev #############
##################################################################

# Ethereum: Fallback RPC provider (less reliable than Alchemy)
# Get free key at: https://infura.io/
# Used by: wallet connections as fallback
INFURA_KEY=<key>

# Block Explorers: For verifying transactions, fetching contract ABIs
# Get free keys at: https://etherscan.io/apis and https://polygonscan.com/apis
# Used by: transaction verification, contract ABI fetching
ETHERSCAN_API_KEY=<key from etherscan>
POLYGONSCAN_API_KEY=<key from polygonscan>

# Alchemy: Primary blockchain RPC provider for NFT/parcel/wearable data
# Get free keys at: https://www.alchemy.com/ (300M compute units/month free)
# ETH: For Ethereum mainnet (parcels, NFTs, wearables)
# MATIC: For Polygon network (Polygon NFTs, cheaper transactions)
# Used by: NFT ownership checks, parcel data, wallet balances, blockchain reads
ALCHEMY_ETH_API_KEY=<key>
ALCHEMY_MATIC_API_KEY=<key>

# POAP: Proof of Attendance Protocol for event badges
# Get keys at: https://poap.tech/
# Used by: POAP badge verification, event attendance checks
POAP_API_KEY=<key>
POAP_SECRET_KEY=<key>

##################################################################
###### SMART CONTRACT ADDRESSES - Production contracts ##########
##################################################################

# Core Contracts: Main Cryptovoxels smart contracts on Ethereum
# CONTRACT_ADDRESS: Parcels (land) NFT contract
# CREATOR_ADDRESS: Original creator wallet
# OWNER_ADDRESS: Current owner/admin wallet
# NAME_ADDRESS: Username registry contract
# WEARABLE_CONTRACT_ADDRESS: Wearables NFT contract
CONTRACT_ADDRESS=0x79986aF15539de2db9A5086382daEdA917A9CF0C
CREATOR_ADDRESS=0x4f857add94d3c54144a7a1220da0399a187e1c5c
OWNER_ADDRESS=0xa253D7cd38dC2D0B2E65AD42a7e4bEB3C60A83aD
NAME_ADDRESS=0x684Cd10B02CdADE20f1858C6315052d66D1Eafc2
#old name contract: 0x4243a8413a77eb559c6f8eaffa63f46019056d08
WEARABLE_CONTRACT_ADDRESS=0xa58b5224e2fd94020cb2837231b2b0e4247301a6

# Collection Factories: Deploy new wearable collections
# MATIC: Polygon factory (cheaper gas)
# ETH: Ethereum factory
COLLECTION_FACTORY_CONTRACT_MATIC=0x4CDaA2492BFF9793d0F39F222dEF7E364e620eC1
COLLECTION_FACTORY_CONTRACT_ETH=0x59F41e2116F7d1B524C0542ABa0481Ecc0eAccED

# Distributors: Wallets that give free wearables/names to new users
# DISTRIBUTOR_ADDRESS: Free wearables dispenser
# NAME_DISTRIBUTOR_ADDRESS: Free username dispenser
# NAME_DISTRIBUTOR_WALLET_WORDS: Seed phrase for name distributor (ask team)
DISTRIBUTOR_ADDRESS = 0xdb4ed670ad6bb85ac9f94226e46db5fefb117064
NAME_DISTRIBUTOR_ADDRESS = 0x403A87B4E76Df26CE4FDFafB9547503567053453
NAME_DISTRIBUTOR_WALLET_WORDS = "<your_secret_seed_phrase>"

##################################################################
###### ASSET URLS - CDNs and external resources #################
##################################################################

# Maps: Minimap tile images and parcel images
# MAP_URL: Minimap tiles (used 6 files)
# IMG_URL: Parcel screenshot images
# IMG_HOST: Image CDN host
MAP_URL=https://map.cryptovoxels.com/tile
IMG_URL=https://img.cryptovoxels.com/node
IMG_HOST=https://img.cryptovoxels.com

# Textures: Texture compression service
# TEXTURE_HOST: Compressor service (set empty to disable compression)
# TEXTURE_CACHEBUSTER: Cache version for texture updates
TEXTURE_HOST=https://compressor.cryptovoxels.com
TEXTURE_CACHEBUSTER=v5

# Storage: DigitalOcean Spaces for lightmaps, baked lighting
# Used by: lighting system, baked parcel data
SPACES_BUCKET=https://cryptovoxels.sfo2.digitaloceanspaces.com

# Lightmaps: Baked lighting version (commented out = disabled)
# Set to 2 to switch to swatched lightmaps (non swatched maps will fail to load)
# Set to 1 or leave undefined for old behaviour
# LIGHTMAP_VERSION=2

# Audio: Sound effects and background music
# SOUNDS_URL: Sound effects library (used 7 files)
SOUNDS_URL=https://sounds.crvox.com/fx

##################################################################
###### ADVANCED SETTINGS - Specialized features #################
##################################################################

# Baking: Lightmap baking job queue table name
# Change this to run multiple baker versions simultaneously (must match /^jobs[a-z0-9_]*$/)
# Used by: lightmap baking system
JOBS_TABLE_NAME=jobs

# LiveKit: Voice/video chat service
# Get keys from LiveKit dashboard
# Used by: voice chat feature
LIVEKIT_API_KEY=<your_livekit_api_key>
LIVEKIT_API_SECRET=<your_livekit_api_secret>
